/app/build/
/app/app/build/
*.dex
*.class
*.jar

# Generated files
gen/
.gradle/

# Keystore (sensitive)
*.jks
*.keystore

# Python / Flask
__pycache__/
*.py[cod]
*$py.class
venv/
env/
.venv/
*.egg-info/
dist/
build/
*.egg

